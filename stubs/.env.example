APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

CORS_ALLOWED_ORIGINS="${APP_URL}"

APP_LANGUAGES=en:English,tr:Türkçe
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

ACTIVITY_LOG_ENABLED=true

# Passport OAuth2 token lifetimes (overrides defaults set in StarterKitServiceProvider)
# PASSPORT_TOKEN_DAYS=15
# PASSPORT_REFRESH_TOKEN_DAYS=30

# Starter Kit package
# Default per-page value returned by DatatableQueryBuilder when the caller
# does not override it via perPage() or ?per_page=.
# STARTER_KIT_DATATABLE_PER_PAGE=10

# APP_DISPLAY_TIMEZONE=UTC

VITE_APP_NAME="${APP_NAME}"
# Otomatik eklenen key'ler (2026-03-04)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=starter_kit_12
DB_USERNAME=root
DB_PASSWORD=
CACHE_PREFIX=_
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=
DO_SPACES_ENDPOINT=
DO_SPACES_BUCKET=
DO_SPACES_URL=
# Auto-added keys (2026-03-08)
APP_TIMEZONE=Europe/Istanbul
# Auto-added keys (2026-03-12)
MEDIA_DISK=local
