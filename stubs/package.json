{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build && vite build --ssr",
        "test": "vitest run",
        "commit": "cz",
        "prepare": "husky"
    },
    "config": {
        "commitizen": {
            "path": "cz-customizable"
        },
        "cz-customizable": {
            "config": ".cz-config.cjs"
        }
    },
    "lint-staged": {
        "!(packages/**)*.{js,ts,vue}": [
            "prettier --write",
            "eslint --fix"
        ],
        "!(packages/**)*.{css,scss}": [
            "prettier --write"
        ],
        "!(packages/**)*.php": [
            "./vendor/bin/pint"
        ]
    },
    "devDependencies": {
        "@commitlint/cli": "^20.4.3",
        "@commitlint/config-conventional": "^20.4.3",
        "@eslint/js": "^10.0.1",
        "@laravel/vite-plugin-wayfinder": "^0.1.7",
        "@primevue/auto-import-resolver": "^4.5.4",
        "@tailwindcss/vite": "^4.0.0",
        "@types/node": "^25.3.3",
        "@vitejs/plugin-vue": "^6.0.4",
        "@vue/test-utils": "^2.4.6",
        "axios": "^1.11.0",
        "commitizen": "^4.3.1",
        "concurrently": "^9.0.1",
        "cz-customizable": "^7.5.1",
        "eslint": "^10.0.2",
        "eslint-plugin-vue": "^10.8.0",
        "husky": "^9.1.7",
        "jsdom": "^28.1.0",
        "laravel-vite-plugin": "^2.0.0",
        "lint-staged": "^16.3.2",
        "prettier": "^3.8.1",
        "sass-embedded": "^1.97.3",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "unplugin-auto-import": "^21.0.0",
        "unplugin-vue-components": "^31.0.0",
        "vite": "^7.0.7",
        "vitest": "^4.0.18",
        "vue-tsc": "^3.2.5"
    },
    "dependencies": {
        "@inertiajs/vue3": "^3.0.3",
        "@primevue/themes": "^4.5.4",
        "@vueuse/core": "^14.2.1",
        "laravel-vue-i18n": "^2.8.0",
        "primeicons": "^7.0.0",
        "primevue": "^4.5.4",
        "vue": "^3.5.29"
    }
}
